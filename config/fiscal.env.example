# Copie para config/fiscal.env e preencha (nunca commitar fiscal.env)
# Carregado por scripts/run-backend-prod.ps1 e documentado em SETUP_PROD.md

FISCAL_MODE=production

# CNPJ do empregador / prestador (somente dígitos)
FISCAL_EMPLOYER_CNPJ=00000000000000
FISCAL_NFSE_PRESTADOR_CNPJ=00000000000000
FISCAL_NFSE_MUNICIPIO_IBGE=3550308

# Certificados A1 (.pfx) — paths relativos à raiz do repo ou absolutos
FISCAL_ESOCIAL_CERT_PATH=./config/certs/esocial.pfx
FISCAL_ESOCIAL_CERT_PASSWORD=altere_a_senha_do_pfx
FISCAL_NFSE_CERT_PATH=./config/certs/nfse.pfx
FISCAL_NFSE_CERT_PASSWORD=altere_a_senha_do_pfx

# eSocial: 1=produção, 2=produção restrita (homologação)
FISCAL_ESOCIAL_TP_AMB=2
